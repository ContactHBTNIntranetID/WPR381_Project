<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manage Enquiries | Advanced Events</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="navbar">
        <div class="logo"><h2>Advanced Events</h2></div>
        <div class="nav-links">
            <a href="/dashboard/admin">Dashboard</a>
            <a href="/auth/logout">Logout</a>
        </div>
    </div>

    <div class="container">
        <h1>Manage Enquiries</h1>

        <% if (enquiries && enquiries.length > 0) { %>
            <% enquiries.forEach(enquiry => { %>
                <div class="card" style="margin-bottom:20px;">
                    <p><strong>From:</strong> <%= enquiry.name %> (<%= enquiry.email %>)</p>
                    <p><strong>Subject:</strong> <%= enquiry.subject %></p>
                    <p><strong>Message:</strong> <%= enquiry.message %></p>
                    <p><strong>Status:</strong> <%= enquiry.status %></p>
                    <p><strong>Date:</strong> <%= new Date(enquiry.createdAt).toDateString() %></p>

                    <% if (enquiry.status !== 'resolved') { %>
                        <div style="margin-top:10px;">
                            <button onclick="updateStatus('<%= enquiry._id %>', 'read')">Mark as Read</button>
                            <button onclick="updateStatus('<%= enquiry._id %>', 'resolved')">Mark Resolved</button>
                        </div>
                    <% } %>
                </div>
            <% }) %>
        <% } else { %>
            <p>No enquiries yet.</p>
        <% } %>
    </div>

    <script>
        function updateStatus(id, status) {
            fetch('/enquiries/status/' + id, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) location.reload();
                else alert(data.message);
            });
        }
    </script>
</body>
</html>

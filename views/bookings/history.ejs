<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Bookings | Advanced Events</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="navbar">
        <div class="logo"><h2>Advanced Events</h2></div>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/dashboard/user">Dashboard</a>
            <a href="/auth/logout">Logout</a>
        </div>
    </div>

    <div class="container">
        <h1>My Bookings</h1>
        <% if (bookings && bookings.length > 0) { %>
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:#333; color:white;">
                        <th style="padding:10px;">Event</th>
                        <th>Date</th>
                        <th>Tickets</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% bookings.forEach(booking => { %>
                        <tr style="border-bottom:1px solid #ddd;">
                            <td style="padding:10px;"><%= booking.eventId ? booking.eventId.title : 'N/A' %></td>
                            <td><%= booking.eventId ? new Date(booking.eventId.date).toDateString() : 'N/A' %></td>
                            <td><%= booking.ticketCount %></td>
                            <td><%= booking.status %></td>
                            <td>
                                <% if (booking.status === 'confirmed') { %>
                                    <button onclick="cancelBooking('<%= booking._id %>')">Cancel</button>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p>No bookings yet. <a href="/events">Browse events</a></p>
        <% } %>
    </div>

    <script>
        function cancelBooking(id) {
            if (!confirm('Cancel this booking?')) return;
            fetch('/bookings/cancel/' + id, { method: 'DELETE' })
                .then(r => r.json())
                .then(data => {
                    if (data.success) location.reload();
                    else alert(data.message);
                });
        }
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Admin Events | Advanced Events</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <!-- NAVBAR -->
    <div class="navbar">
        <div class="logo">
            <h2>Admin Panel</h2>
        </div>

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/dashboard">Dashboard</a>
        </div>
    </div>

    <!-- ADMIN CONTENT -->
    <div class="container">

        <h1>Manage Events</h1>

        <div class="events">

            <div class="card">
                <h3>Create Event</h3>
                <p>Add new events to the system</p>
                <button>Create</button>
            </div>

            <div class="card">
                <h3>Edit Events</h3>
                <p>Update existing event details</p>
                <button>Edit</button>
            </div>

            <div class="card">
                <h3>Delete Events</h3>
                <p>Remove cancelled events</p>
                <button>Delete</button>
            </div>

        </div>

    </div>

</body>
</html>
    <!DOCTYPE html>
    <html lang="en">

    <head>
        <meta charset="UTF-8">
        <title>Home | Advanced Events</title>
        <link rel="stylesheet" href="/css/style.css">
    </head>

    <body>

        <!-- NAVBAR (PAGE SWITCHING) -->
        <div class="navbar">
            <div class="logo">
                <h2>Advanced Events</h2>
            </div>

            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/login">Login</a>
                <a href="/register">Register</a>
                <a href="/contact">Contact</a>
            </div>
        </div>

        <!-- HERO SECTION -->
        <div class="hero">
            <h1>Discover Amazing Events</h1>
            <p>Book tickets for conferences, festivals, and workshops</p>
        </div>

        <!-- MAIN CONTENT -->
        <div class="container">

            <!-- SEARCH BAR -->
            <div style="text-align:center; margin-bottom:20px;">
                <input type="text" placeholder="Search events..." />
            </div>

            <!-- EVENTS GRID -->
            <div class="events">

                <% if (events && events.length > 0) { %>

                    <% events.forEach(event => { %>

                        <div class="card">
                            <h3><%= event.title %></h3>
                            <p><%= event.location %></p>
                            <p><%= event.date.toDateString() %></p>

                            <div style="margin-top:10px;">
                                <strong>R <%= event.price %></strong>
                            </div>

                            <button style="margin-top:10px; width:100%;">
                                Book Ticket
                            </button>
                        </div>

                    <% }) %>

                <% } else { %>

                    <p style="text-align:center;">No events available</p>

                <% } %>

            </div>

        </div>

        <!-- FOOTER -->
        <div style="text-align:center; padding:20px; margin-top:40px; background:#111; color:white;">
            © 2026 Advanced Events Platform
        </div>

    </body>
    </html>
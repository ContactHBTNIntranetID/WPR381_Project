//<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Dashboard | Advanced Events</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <!-- NAVBAR -->
    <div class="navbar">
        <div class="logo">
            <h2>Advanced Events</h2>
        </div>

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/login">Logout</a>
        </div>
    </div>

    <!-- DASHBOARD CONTAINER -->
    <div class="container">

        <h1>User Dashboard</h1>

        <!-- STATS SECTION -->
        <div class="events">

            <div class="card">
                <h3>Total Bookings</h3>
                <p><%= bookings.length %></p>
            </div>

        </div>

        <h2 style="margin-top:30px;">Your Bookings</h2>

        <!-- BOOKINGS LIST -->
        <div class="events">

            <% if (bookings && bookings.length > 0) { %>

                <% bookings.forEach(booking => { %>

                    <div class="card">

                        <h3><%= booking.eventId.title %></h3>

                        <p><strong>Tickets:</strong> <%= booking.ticketCount %></p>

                        <p>
                            <strong>Status:</strong>
                            <span style="color:green;">
                                <%= booking.status %>
                            </span>
                        </p>

                    </div>

                <% }) %>

            <% } else { %>

                <p>No bookings yet.</p>

            <% } %>

        </div>

    </div>

</body>
</html>
<%- include('../partials/header') %>
<div class="container">
  <h1>Admin Dashboard</h1>

  <div class="events" style="margin-bottom:30px;">
    <div class="card" style="text-align:center;">
      <h2><%= stats.totalEvents %></h2>
      <p>Total Events</p>
    </div>
    <div class="card" style="text-align:center;">
      <h2><%= stats.totalBookings %></h2>
      <p>Total Bookings</p>
    </div>
    <div class="card" style="text-align:center;">
      <h2><%= stats.totalUsers %></h2>
      <p>Registered Users</p>
    </div>
    <div class="card" style="text-align:center;">
      <h2>R <%= stats.totalRevenue.toFixed(2) %></h2>
      <p>Total Revenue</p>
    </div>
  </div>

  <h2>Popular Events</h2>
  <table style="width:100%; border-collapse:collapse; background:white; border-radius:10px; overflow:hidden; margin-bottom:30px; box-shadow:0 2px 8px rgba(0,0,0,0.08);">
    <thead style="background:#111; color:white;">
      <tr>
        <th style="padding:12px; text-align:left;">Event</th>
        <th style="padding:12px; text-align:left;">Bookings</th>
        <th style="padding:12px; text-align:left;">Tickets Sold</th>
      </tr>
    </thead>
    <tbody>
      <% popularEvents.forEach(item => { %>
        <tr>
          <td style="padding:11px 12px;"><%= item.event.title %></td>
          <td style="padding:11px 12px;"><%= item.bookings %></td>
          <td style="padding:11px 12px;"><%= item.tickets %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <h2>Capacity Usage</h2>
  <div id="capacityBars">
    <% capacityUsage.forEach((item, index) => { %>
      <div style="margin-bottom:12px;">
        <div style="display:flex; justify-content:space-between; font-size:14px; margin-bottom:4px;">
          <span><%= item.title %></span>
          <span><%= item.used %>/<%= item.total %> (<%= item.percentage.toFixed(0) %>%)</span>
        </div>
        <div style="background:#e0e0e0; border-radius:10px; height:10px;">
          <div
            class="capacity-bar"
            data-percentage="<%= item.percentage.toFixed(0) %>"
            style="background:#4a90e2; height:10px; border-radius:10px; width:0%;">
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <h2 style="margin-top:30px;">Recent Bookings</h2>
  <table style="width:100%; border-collapse:collapse; background:white; border-radius:10px; overflow:hidden; margin-bottom:30px; box-shadow:0 2px 8px rgba(0,0,0,0.08);">
    <thead style="background:#111; color:white;">
      <tr>
        <th style="padding:12px; text-align:left;">User</th>
        <th style="padding:12px; text-align:left;">Event</th>
        <th style="padding:12px; text-align:left;">Tickets</th>
        <th style="padding:12px; text-align:left;">Status</th>
        <th style="padding:12px; text-align:left;">Date</th>
      </tr>
    </thead>
    <tbody>
      <% recentBookings.forEach(booking => { %>
        <tr>
          <td style="padding:11px 12px;"><%= booking.user ? booking.user.name : 'N/A' %></td>
          <td style="padding:11px 12px;"><%= booking.event ? booking.event.title : 'N/A' %></td>
          <td style="padding:11px 12px;"><%= booking.numberOfTickets %></td>
          <td style="padding:11px 12px;"><%= booking.status %></td>
          <td style="padding:11px 12px;"><%= new Date(booking.createdAt).toDateString() %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div style="display:flex; gap:10px;">
    <a href="/events/create"><button>Create New Event</button></a>
    <a href="/events"><button style="background:#888;">Manage Events</button></a>
    <a href="/enquiries"><button style="background:#888;">View Enquiries</button></a>
  </div>
</div>

<script>
  window.addEventListener('DOMContentLoaded', function () {
    var bars = document.querySelectorAll('.capacity-bar');
    bars.forEach(function (bar) {
      var pct = bar.getAttribute('data-percentage');
      bar.style.width = pct + '%';
    });
  });
</script>

<%- include('../partials/footer') %>
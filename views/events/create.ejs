<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Create Event | Advanced Events</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="navbar">
        <div class="logo"><h2>Advanced Events</h2></div>
        <div class="nav-links">
            <a href="/dashboard/admin">Dashboard</a>
            <a href="/auth/logout">Logout</a>
        </div>
    </div>

    <div class="auth-box" style="max-width:600px;">
        <h2>Create Event</h2>
        <% if (typeof error !== 'undefined' && error) { %>
            <p style="color:red;"><%= error %></p>
        <% } %>
        <form action="/events/admin/create" method="POST">
            <input type="text" name="title" placeholder="Event Title" required>
            <textarea name="description" placeholder="Description" rows="4" required></textarea>
            <select name="category" required>
                <option value="">Select Category</option>
                <option value="conference">Conference</option>
                <option value="workshop">Workshop</option>
                <option value="festival">Festival</option>
                <option value="private">Private</option>
                <option value="other">Other</option>
            </select>
            <input type="datetime-local" name="date" required>
            <input type="text" name="location" placeholder="Location" required>
            <input type="text" name="venue" placeholder="Venue (optional)">
            <input type="number" name="capacity" placeholder="Capacity" min="1" required>
            <input type="number" name="price" placeholder="Price (R)" min="0" step="0.01" value="0">
            <button type="submit">Create Event</button>
        </form>
    </div>
</body>
</html>

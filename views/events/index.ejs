<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %> | Advanced Events</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="navbar">
        <div class="logo"><h2>Advanced Events</h2></div>
        <div class="nav-links">
            <a href="/">Home</a>
            <% if (typeof user !== 'undefined' && user) { %>
                <% if (user.role === 'admin') { %><a href="/dashboard/admin">Admin Dashboard</a><% } %>
                <a href="/dashboard/user">My Dashboard</a>
                <a href="/enquiries/contact">Contact</a>
                <a href="/auth/logout">Logout</a>
            <% } else { %>
                <a href="/auth/login">Login</a>
                <a href="/auth/register">Register</a>
            <% } %>
        </div>
    </div>

    <div class="hero">
        <h1>Discover Amazing Events</h1>
        <p>Book tickets for conferences, festivals, and workshops</p>
    </div>

    <div class="container">
        <form action="/events" method="GET" style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:20px;">
            <input type="text" name="search" placeholder="Search events..." value="<%= filters.search || '' %>">
            <select name="category">
                <option value="all">All Categories</option>
                <% categories.forEach(cat => { %>
                    <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat %></option>
                <% }) %>
            </select>
            <select name="sort">
                <option value="date_asc" <%= filters.sort === 'date_asc' ? 'selected' : '' %>>Date (Earliest)</option>
                <option value="date_desc" <%= filters.sort === 'date_desc' ? 'selected' : '' %>>Date (Latest)</option>
                <option value="price_asc" <%= filters.sort === 'price_asc' ? 'selected' : '' %>>Price (Low-High)</option>
                <option value="price_desc" <%= filters.sort === 'price_desc' ? 'selected' : '' %>>Price (High-Low)</option>
            </select>
            <button type="submit">Filter</button>
        </form>

        <div class="events">
            <% if (events && events.length > 0) { %>
                <% events.forEach(event => { %>
                    <div class="card">
                        <h3><%= event.title %></h3>
                        <p><strong>Category:</strong> <%= event.category %></p>
                        <p><strong>Date:</strong> <%= new Date(event.date).toDateString() %></p>
                        <p><strong>Location:</strong> <%= event.location %></p>
                        <p><strong>Tickets left:</strong> <%= event.ticketsRemaining %></p>
                        <strong>R <%= event.price %></strong>
                        <a href="/events/<%= event._id %>"><button style="margin-top:10px; width:100%;">View Details</button></a>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="text-align:center;">No events found.</p>
            <% } %>
        </div>
    </div>

    <div style="text-align:center; padding:20px; margin-top:40px; background:#111; color:white;">
        &copy; 2026 Advanced Events Platform
    </div>
</body>
</html>

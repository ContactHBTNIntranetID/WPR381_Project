<%- include('../partials/header') %>
<div class="hero">
  <h1>Discover Amazing Events</h1>
  <p>Book tickets for conferences, festivals, and workshops</p>
</div>
<div class="container">
  <form method="GET" action="/events" style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:20px;">
    <input type="text" name="search" placeholder="Search events..." value="<%= filters.search || '' %>">
    <select name="category" style="padding:10px; border:1px solid #ccc; border-radius:6px;">
      <option value="all">All Categories</option>
      <% categories.forEach(cat => { %>
        <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat %></option>
      <% }) %>
    </select>
    <input type="date" name="date" value="<%= filters.date || '' %>" style="padding:10px; border:1px solid #ccc; border-radius:6px;">
    <select name="sort" style="padding:10px; border:1px solid #ccc; border-radius:6px;">
      <option value="date_asc"  <%= filters.sort === 'date_asc'   ? 'selected' : '' %>>Date (Earliest)</option>
      <option value="date_desc" <%= filters.sort === 'date_desc'  ? 'selected' : '' %>>Date (Latest)</option>
      <option value="price_asc" <%= filters.sort === 'price_asc'  ? 'selected' : '' %>>Price (Low)</option>
      <option value="price_desc"<%= filters.sort === 'price_desc' ? 'selected' : '' %>>Price (High)</option>
    </select>
    <button type="submit">Search</button>
    <a href="/events"><button type="button" style="background:#888;">Clear</button></a>
  </form>

  <div class="events">
    <% if (events && events.length > 0) { %>
      <% events.forEach(event => { %>
        <div class="card">
          <h3><%= event.title %></h3>
          <p><%= event.location %></p>
          <p><%= moment(event.date).format('DD MMM YYYY, HH:mm') %></p>
          <p><%= event.availableTickets %> tickets left</p>
          <div style="margin-top:10px; display:flex; justify-content:space-between; align-items:center;">
            <strong>R <%= event.price %></strong>
            <a href="/events/<%= event._id %>"><button>View</button></a>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="center">No events found.</p>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
<%- include('../partials/header') %>
<div class="container">
  <div class="auth-box" style="width:100%; max-width:600px;">
    <h2>Edit Event</h2>
    <% if (error) { %>
      <p style="color:red; margin-bottom:10px;"><%= error %></p>
    <% } %>
    <form action="/events/<%= event._id %>?_method=PUT" method="POST">
      <input type="text" name="title" value="<%= event.title %>" required>
      <textarea name="description" rows="4" required style="padding:10px; border:1px solid #ccc; border-radius:6px; font-family:Arial;"><%= event.description %></textarea>
      <input type="datetime-local" name="date" value="<%= new Date(event.date).toISOString().slice(0,16) %>" required style="padding:10px; border:1px solid #ccc; border-radius:6px; width:100%;">
      <select name="category" required style="padding:10px; border:1px solid #ccc; border-radius:6px;">
        <% ['Conference','Workshop','Festival','Corporate','Private','Other'].forEach(cat => { %>
          <option value="<%= cat %>" <%= event.category === cat ? 'selected' : '' %>><%= cat %></option>
        <% }) %>
      </select>
      <input type="text" name="location" value="<%= event.location %>" required>
      <input type="number" name="price" value="<%= event.price %>" min="0" step="0.01" required>
      <input type="number" name="totalCapacity" value="<%= event.totalCapacity %>" min="1" required>
      <select name="status" style="padding:10px; border:1px solid #ccc; border-radius:6px;">
        <% ['upcoming','ongoing','completed','cancelled'].forEach(s => { %>
          <option value="<%= s %>" <%= event.status === s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
      <button type="submit">Update Event</button>
      <a href="/events/<%= event._id %>"><button type="button" style="background:#888; width:100%; margin-top:6px;">Cancel</button></a>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
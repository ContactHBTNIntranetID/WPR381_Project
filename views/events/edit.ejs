<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Event | Advanced Events</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="navbar">
        <div class="logo"><h2>Advanced Events</h2></div>
        <div class="nav-links">
            <a href="/dashboard/admin">Dashboard</a>
            <a href="/auth/logout">Logout</a>
        </div>
    </div>

    <div class="auth-box" style="max-width:600px;">
        <h2>Edit Event</h2>
        <% if (typeof error !== 'undefined' && error) { %>
            <p style="color:red;"><%= error %></p>
        <% } %>
        <form action="/events/admin/edit/<%= event._id %>" method="POST">
            <input type="hidden" name="_method" value="PUT">
            <input type="text" name="title" value="<%= event.title %>" required>
            <textarea name="description" rows="4" required><%= event.description %></textarea>
            <select name="category" required>
                <% ['conference','workshop','festival','private','other'].forEach(cat => { %>
                    <option value="<%= cat %>" <%= event.category === cat ? 'selected' : '' %>><%= cat %></option>
                <% }) %>
            </select>
            <input type="datetime-local" name="date" value="<%= new Date(event.date).toISOString().slice(0,16) %>" required>
            <input type="text" name="location" value="<%= event.location %>" required>
            <input type="text" name="venue" value="<%= event.venue || '' %>">
            <input type="number" name="capacity" value="<%= event.capacity %>" min="1" required>
            <input type="number" name="price" value="<%= event.price %>" min="0" step="0.01">
            <select name="status">
                <% ['upcoming','ongoing','completed','cancelled'].forEach(s => { %>
                    <option value="<%= s %>" <%= event.status === s ? 'selected' : '' %>><%= s %></option>
                <% }) %>
            </select>
            <button type="submit">Save Changes</button>
        </form>
        <p><a href="/events/<%= event._id %>">&larr; Back to event</a></p>
    </div>
</body>
</html>
